PROJECT_NAME="AI Career Copilot API"
PROJECT_VERSION="0.1.0"
API_V1_STR="/api/v1"

MONGODB_URI="mongodb://localhost:27017"
DATABASE_NAME="ai_career_copilot"

# GenAI Settings
OPENAI_API_KEY="sk-..."

# LangGraph Tracing (Optional but recommended)
LANGCHAIN_API_KEY="..."
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT="ai-career-copilot"

# Secret Keys for JWT (Generate using `openssl rand -hex 32`)
SECRET_KEY="your-super-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

MAIL_USERNAME="your-gmail-address@gmail.com"
MAIL_PASSWORD="your-google-app-password"
MAIL_FROM="your-gmail-address@gmail.com"
MAIL_PORT=587
MAIL_SERVER="smtp.gmail.com"
MAIL_STARTTLS=True
MAIL_SSL_TLS=False